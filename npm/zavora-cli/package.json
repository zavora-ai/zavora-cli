{
  "name": "@zavora-ai/zavora-cli",
  "version": "1.1.4",
  "description": "Installable binary wrapper for zavora-cli",
  "license": "MIT",
  "homepage": "https://github.com/zavora-ai/zavora-cli",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zavora-ai/zavora-cli.git"
  },
  "bugs": {
    "url": "https://github.com/zavora-ai/zavora-cli/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "os": [
    "darwin",
    "linux"
  ],
  "cpu": [
    "x64",
    "arm64"
  ],
  "bin": {
    "zavora-cli": "bin/zavora-cli.js"
  },
  "scripts": {
    "postinstall": "node scripts/install.js",
    "prepack": "node scripts/install.js --dry-run"
  },
  "files": [
    "bin",
    "scripts",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  }
}
